# ── Parser backend ────────────────────────────────────────────────────────────
# Point /api/parse at the running FastAPI backend.
# When unset, the playground falls back to the in-process mock automatically.
#
# Start the backend first:
#   poetry install --with api
#   poetry run uvicorn api.main:app --reload --port 8000
#
PARSER_API_URL=http://localhost:8000

# ── Parser profile (read by the FastAPI backend via TLUSR_PARSER_* prefix) ───
# TLUSR_PARSER_PROFILE=balanced          # fast | balanced | accurate

# ── LLM fallback (optional — enables Tier 3 extraction) ──────────────────────
# TLUSR_PARSER_LLM__ENABLED=true
# TLUSR_PARSER_LLM__PROVIDER=openai      # openai | anthropic | gemini | local
# TLUSR_PARSER_LLM__API_KEY=sk-...
# TLUSR_PARSER_LLM__MODEL=gpt-4o-mini

# ── API CORS (set in the backend process, not here) ───────────────────────────
# CORS_ORIGINS=http://localhost:3000
